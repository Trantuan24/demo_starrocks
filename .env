# ════════════════════════════════════════════════
# Demo: Kafka → StarRocks → Superset
# Environment Variables
# ════════════════════════════════════════════════

# Producer
EVENTS_PER_SECOND=2

# Superset
SUPERSET_SECRET_KEY=demo_secret_key_starrocks_2026
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@demo.local
ADMIN_PASSWORD=admin

# ── Demo B (Iceberg serving mart) ──
# MinIO credentials (S3 storage cho Iceberg)
MINIO_USER=minio
MINIO_PASSWORD=minio12345
# Số dòng mock data seed vào Iceberg DTM (fact_sales)
SEED_ROWS=1000000
